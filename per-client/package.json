{
  "name": "my-app",
  "version": "0.0.0",
  "scripts": {
    "prebuild": "node src/pre-build/build-templates.js",
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration production --verbose",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:per-client": "node dist/per-client/server/server.mjs",
    "bundle-report": "ng build --configuration=production --source-map && source-map-explorer dist/*.js"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.8.0",
  "dependencies": {
    "@angular/cdk": "~21.1.3",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/material": "~21.1.3",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@antmedia/web_player": "^2.11.11",
    "@antmedia/webrtc_adaptor": "^2.13.2",
    "@fancyapps/ui": "^5.0.36",
    "@jsverse/transloco-persist-lang": "^8.1.0",
    "bufferutil": "^4.0.9",
    "express": "^5.1.0",
    "jwt-decode": "^4.0.0",
    "nanoid": "^5.1.5",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "utf-8-validate": "^6.0.5",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.3",
    "@angular/cli": "^21.1.3",
    "@angular/compiler-cli": "^21.1.0",
    "@angular/material": "^21.1.3",
    "@types/jasmine": "~5.1.7",
    "@types/uuid": "^10.0.0",
    "jasmine-core": "~5.6.0",
    "jsdom": "^27.1.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}